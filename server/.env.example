# Local dev: use separate files for ERD userprofile vs trips (recommended)
USERPROFILE_DATABASE_URL=sqlite:///./userprofile.db
TRIPS_DATABASE_URL=sqlite:///./trips.db
DATABASE_URL=sqlite:///./trips.db
# ERD split databases (recommended for production)
# USERPROFILE_DATABASE_URL=postgresql://USER:PASS@HOST:5432/userprofile?sslmode=require
# TRIPS_DATABASE_URL=postgresql://USER:PASS@HOST:5432/Pet_friendly_travel?sslmode=require
# Run app/schemas/postgres_userprofile.sql and postgres_trips.sql on each DB once.

JWT_SECRET_KEY=dev-only-change-me
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=3600
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:5173,http://localhost:5173
CORS_ALLOW_CREDENTIALS=true

# Required for live trip search (GET /api/v1/trips/search)
RAPIDAPI_KEY=
GEOAPIFY_API_KEY=
# Optional: Booking.com pet filter for hotel search
# BOOKING_PET_CATEGORIES_FILTER_IDS=

# Optional Amadeus (legacy /travel routes)
# AMADEUS_CLIENT_ID=
# AMADEUS_CLIENT_SECRET=
